{
  "layer": "top",
  "position": "top", 
  "height": 40,
  
  "modules-left":   ["hyprland/workspaces"],
  "modules-center": ["hyprland/language#icon","hyprland/language","clock#icon_time","clock#time","clock#icon_date","clock#date","custom/notification","idle_inhibitor","custom/nvidia"],
  "modules-right":  [
      "tray",
      "network#icon","network", 
      "pulseaudio#icon","pulseaudio",
      "group/group-power"],

  "hyprland/workspaces": {
	"format": "{name}",
    "disable-scroll": false,
    "all-outputs": false,
    "on-click": "activate",
    "show-special": false,
    },

    "hyprland/language#icon": {
        "format": "¾░îî ",
    },

    "hyprland/language": {
    "format": "{}",
    "format-de": "de",
    "format-en": "uk",
    },

"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "<span foreground='#f38ba8'>¾░àÂ</span>",
        "deactivated": "¾░øè"
        }
},

"custom/dunst": {
    "exec": "~/.config/waybar/scripts/notifications",
    "on-click": "dunstctl set-paused toggle",
    "on-click-right": "dunstctl history-pop",
    "restart-interval": 1,
},

"custom/nvidia": {
    "exec": "~/.config/waybar/scripts/nvidia",
    "restart-interval": 1,
},

"custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span foreground='#f38ba8'>´éó</span>",
      "none": "´éó",
      "dnd-notification": "<span foreground='#f38ba8'>´çÀ</span>",
      "dnd-none": "´çÀ",
      "inhibited-notification": "<span foreground='#f38ba8'>´éó</span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "<span foreground='#f38ba8'>´çÀ</span>",
      "dnd-inhibited-none": "´çÀ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click-right": "swaync-client -op &",
    "on-click": "swaync-client -d -sw",
    "on-click-middle": "swaync-client -C",
    "escape": false
},

"custom/pomo":{
    "restart-interval": 1,
    "return-type":"json",
    "exec": "~/.config/waybar/scripts/pomo",
    "format": "{}"
},

  "tray": {
