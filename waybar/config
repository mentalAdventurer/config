        "on-scroll-up": "~/.config/waybar/scripts/brightness -qs up",
        "on-scroll-down": "~/.config/waybar/scripts/brightness -qs down"
    },
    "battery": {
        "interval": 3,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "<span foreground='#b9f27c'>{icon}</span> {capacity}%",
        "format-plugged": "<span foreground='#b9f27c'>{icon}</span> {capacity}%",
        "format-alt": "{icon} {power:.1f}W",
        "format-icons": [
            "<span foreground='#f7768e'>ï‰„</span>",
            "<span foreground='#f7768e'>ï‰ƒ</span>",
            "<span foreground='#ff9e64'>ï‰ƒ</span>",
