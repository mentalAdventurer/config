{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-bottom": 0,
    "margin-left": 10,
    "margin-right": 10,
    "margin-top": 10,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/language",
        "clock#time",
        "clock#date",
        "custom/notification",
        "idle_inhibitor"
    ],
    "modules-right": [
        "tray",
        "network",
        "pulseaudio",
        "group/group-power"
    ],
    "hyprland/workspaces": {
        "format": "{name}",
        "disable-scroll": false,
        "all-outputs": false,
        "on-click": "activate",
        "show-special": false
    },
    "hyprland/language": {
        "format": "َ°ŒŒ {}",
        "format-de": "de",
        "format-en": "uk"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "<span foreground='#f7768e'>َ°…¶</span>",
            "deactivated": "َ°›ٹ"
        }
    },
    "custom/nvidia": {
        "exec": "~/.config/waybar/scripts/nvidia",
        "restart-interval": 1
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "<span foreground='#f7768e'>ï‚¢</span>",
            "none": "ï‚¢",
            "dnd-notification": "<span foreground='#f7768e'>ï‡·</span>",
            "dnd-none": "ï‡·",
