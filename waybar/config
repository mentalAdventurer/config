            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "<span foreground='#f7768e'>ï‡·</span>",
            "dnd-inhibited-none": "ï‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click-right": "swaync-client -op &",
        "on-click": "swaync-client -d -sw",
        "on-click-middle": "swaync-client -C",
        "escape": false
    },
    "custom/pomo": {
        "restart-interval": 1,
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/pomo",
        "format": "{}"
    },
    "tray": {
        "icon-size": 13,
        "spacing": 10
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": [
            "َ°«ƒ",
            "َ°«„",
