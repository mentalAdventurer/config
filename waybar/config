{
  "layer": "top",
  "position": "top", 
  "height": 40,
  
  "modules-left":   ["hyprland/workspaces"],
  "modules-center": ["hyprland/language#icon","hyprland/language","clock#icon_time","clock#time","clock#icon_date","clock#date","custom/notification","idle_inhibitor","custom/nvidia"],
  "modules-right":  [
      "tray",
      "network#icon","network", 
      "pulseaudio#icon","pulseaudio",
      "group/group-power"],

  "hyprland/workspaces": {
	"format": "{name}",
    "disable-scroll": false,
    "all-outputs": false,
    "on-click": "activate",
    "show-special": false,
    },

    "hyprland/language#icon": {
        "format": "≤░ΝΝ ",
    },

    "hyprland/language": {
    "format": "{}",
    "format-de": "de",
    "format-en": "uk",
    },

"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "<span foreground='#f38ba8'>≤░Ζ╢</span>",
        "deactivated": "≤░δΛ"
        }
},

"custom/dunst": {
    "exec": "~/.config/waybar/scripts/notifications",
    "on-click": "dunstctl set-paused toggle",
    "on-click-right": "dunstctl history-pop",
    "restart-interval": 1,
},

"custom/nvidia": {
    "exec": "~/.config/waybar/scripts/nvidia",
    "restart-interval": 1,
},

"custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span foreground='#f38ba8'>ΎΓλ</span>",
      "none": "ΎΓλ",
      "dnd-notification": "<span foreground='#f38ba8'>ΎΘ╖</span>",
      "dnd-none": "ΎΘ╖",
      "inhibited-notification": "<span foreground='#f38ba8'>ΎΓλ</span>",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "<span foreground='#f38ba8'>ΎΘ╖</span>",
      "dnd-inhibited-none": "ΎΘ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click-right": "swaync-client -op &",
    "on-click": "swaync-client -d -sw",
    "on-click-middle": "swaync-client -C",
    "escape": false
},

"custom/pomo":{
    "restart-interval": 1,
    "return-type":"json",
    "exec": "~/.config/waybar/scripts/pomo",
    "format": "{}"
},

  "tray": {
    "icon-size": 13,
    "spacing": 10
  },


  "backlight#icon":{
    "device": "intel_backlight",
    "format": "{icon} ",
    "format-icons": ["≤░τΔ","≤░τΕ","≤░τΖ","≤░τΗ","≤░τΘ","≤░τΙ"],
    "on-scroll-up": "~/.config/waybar/scripts/brightness -qs up",
    "on-scroll-down": "~/.config/waybar/scripts/brightness -qs down",
  },
  "backlight":{
    "device": "intel_backlight",
    "format": "{percent}%",
    "format-icons": ["≤░τΔ","≤░τΕ","≤░τΖ","≤░τΗ","≤░τΘ","≤░τΙ"],
    "on-scroll-up": "~/.config/waybar/scripts/brightness -qs up",
    "on-scroll-down": "~/.config/waybar/scripts/brightness -qs down",
  },

  "battery#icon": {
    "interval": 3,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} ",
    "format-charging": "≤▒ΡΜ ",
    "format-plugged": "≤░ΓΕ ",
    "format-icons": ["≤░ΓΟ","≤░Β║","≤░Β╗","≤░Β╝","≤░Β╜","≤░Β╛","≤░Β┐","≤░ΓΑ","≤░ΓΒ","≤░ΓΓ","≤░Β╣"]
    
  },
  "battery": {
    "interval": 3,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}%",
    "format-charging": "{capacity}%",
    "format-plugged": "{capacity}%",
    "format-alt": "{power:.1f}W",
    "format-icons": ["ΎΨΞ", "ΎΧ╣", "ΎΧ║", "ΎΧ╗", "ΎΧ╝", "ΎΧ╜", "ΎΧ╛", "ΎΧ┐", "ΎΨΑ", "ΎΨΒ", "≤░Β╣"]
  },

  "clock#icon_time": {
      "format": "ΎΑΩ "
  },
  
  "clock#time": {
  "format": "{:%H:%M}",
  "format-alt": "{:%A, %B %d, %Y (%R)}",
  },
  
  "clock#icon_date": {
      "format": "ΎΒ│ ",
  },

  "clock#date": {
      "format": "{:%d.%m}",
  },


  "network#icon": {
    "format-wifi": "{icon} ",
    "format-ethernet": "Ύδ┐ ",
    "format-linked": "{ifname} (No IP) ΎηΨ",
    "format-disconnected": "Ύςσ ",
    "tooltip-format-wifi": "SSID: {essid} | Down Speed: {bandwidthDownBits}, Up Speed: {bandwidthUpBits}",
    "on-click": "~/.config/waybar/scripts/applets start",
    "on-click-right": "~/.config/waybar/scripts/applets end",
    "format-icons": ["≤░νψ","≤░νθ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
  },
  "network": {
    "format-wifi": "{signalStrength}%",
    "format-ethernet": "Ύδ┐ {essid}",
    "format-linked": "{ifname} (No IP) ΎηΨ",
    "format-alt": "{essid}",
    "format-disconnected": "--%",
    "tooltip-format-wifi": "SSID: {essid} | Down Speed: {bandwidthDownBits}, Up Speed: {bandwidthUpBits}",
    "on-click": "~/.config/waybar/scripts/applets start",
    "on-click-right": "~/.config/waybar/scripts/applets end",
    "format-icons": ["≤░νψ","≤░νθ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
  },

  "pulseaudio#icon": {
    "format": "{icon} ",
    "format-muted": "Όυν" ,
    "on-click": "~/.config/waybar/scripts/volume mute",
    "scroll-step": 1,
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "Ύσ╜", "ΎΑρ"]
    }
  },
  "pulseaudio": {
    "format": "{volume}%",
    "format-muted": "--%",
    "on-click": "~/.config/waybar/scripts/volume mute",
    "scroll-step": 1,
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "Ύσ╜", "ΎΑρ"]
    }
  },
    "group/group-power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false,
        },
        "modules": [
            "custom/power", // First element is the "group leader" and won't ever be hidden
            "custom/quit",
            "custom/lock",
            "custom/reboot",
        ]
    },
    "custom/quit": {
        "format": "≤░Ω╝",
        "tooltip": false,
        "on-click": "hyprctl dispatch exit"
    },
    "custom/lock": {
        "format": "≤░ΞΒ",
        "tooltip": false,
        "on-click": "swaylock"
    },
    "custom/reboot": {
        "format": "≤░εΚ",
        "tooltip": false,
        "on-click": "reboot"
    },
    "custom/power": {
        "format": "ΎΑΣ",
        "tooltip": false,
        "on-click": "shutdown now"
    }
}
